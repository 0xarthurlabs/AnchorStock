# Blockchain Configuration
# Update these addresses after deploying contracts
NEXT_PUBLIC_RPC_URL=https://sei-testnet.g.alchemy.com/v2/<Your_Alchemy_Key>
NEXT_PUBLIC_ORACLE_CONTRACT_ADDRESS=
NEXT_PUBLIC_LENDING_POOL_CONTRACT_ADDRESS=
NEXT_PUBLIC_PERP_ENGINE_CONTRACT_ADDRESS=
NEXT_PUBLIC_RWA_TOKEN_CONTRACT_ADDRESS=
NEXT_PUBLIC_USD_TOKEN_CONTRACT_ADDRESS=
NEXT_PUBLIC_A_TOKEN_CONTRACT_ADDRESS=

# Wallet Connect (optional, but recommended)
# Get your project ID from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-project-id

# Backend API
# Update this to match your backend API URL
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3001
