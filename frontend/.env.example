# Blockchain Configuration
# Update these addresses after deploying contracts
NEXT_PUBLIC_APP_ENV=dev
# IMPORTANT: dev/staging/prod must use different chainId
NEXT_PUBLIC_CHAIN_ID=1328
# RPC URL must match env + chainId (no secrets in NEXT_PUBLIC_*)
NEXT_PUBLIC_RPC_URL=https://your-rpc.example
# CSP + runtime safety: comma-separated RPC origins allowed for this env (prod must not include testnet origins)
NEXT_PUBLIC_RPC_ORIGIN_ALLOWLIST=https://your-rpc.example
# Optional anti-tamper for runtime-loaded deployments artifact:
# sha256( textContentOf(`/deployments/${NEXT_PUBLIC_APP_ENV}/${NEXT_PUBLIC_CHAIN_ID}.json`) )
NEXT_PUBLIC_DEPLOYMENTS_SHA256=
NEXT_PUBLIC_ORACLE_CONTRACT_ADDRESS=
NEXT_PUBLIC_LENDING_POOL_CONTRACT_ADDRESS=
NEXT_PUBLIC_PERP_ENGINE_CONTRACT_ADDRESS=
NEXT_PUBLIC_RWA_TOKEN_CONTRACT_ADDRESS=
NEXT_PUBLIC_USD_TOKEN_CONTRACT_ADDRESS=
NEXT_PUBLIC_A_TOKEN_CONTRACT_ADDRESS=

# Wallet Connect (optional, but recommended)
# Get your project ID from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-project-id

# Backend API
# Update this to match your backend API URL
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3001

# --- GitHub Environment variables (for .github/workflows/frontend-release.yml + coordinated-deployments-release.yml) ---
# FRONTEND_SERVICE=anchorstock-frontend-web
# FRONTEND_IMAGE_NAME=anchorstock-frontend
# (Reuse PROJECT_ID, REGION, GAR_REPO, VPC_* from the same Environment as backend.)
