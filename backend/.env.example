# AnchorStock Backend Configuration
# Copy this file to .env and fill in your values

# Blockchain Configuration
RPC_URL=https://sei-testnet.g.alchemy.com/v2/<Your_Alchemy_Key>
PRIVATE_KEY=
ORACLE_CONTRACT_ADDRESS=
LENDING_POOL_CONTRACT_ADDRESS=
PERP_ENGINE_CONTRACT_ADDRESS=

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_PRICE=stock-prices

# TimescaleDB Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=anchorstock
DB_PASSWORD=anchorstock
DB_NAME=anchorstock

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Stock API Configuration
STOCK_API_URL=https://www.alphavantage.co/query
STOCK_API_KEY=<Your_Alphavantage.Co_Key>
# Get free API key at: https://www.alphavantage.co/support/#api-key

RELAYER_FETCH_INTERVAL=5m