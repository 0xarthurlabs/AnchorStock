# AnchorStock Contracts Deployment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Deployment Configuration
# ============================================

# Private Key for deployment (without 0x prefix)
# WARNING: Never commit this to version control!
PRIVATE_KEY=your_private_key_here

# RPC URL for the blockchain network
# Examples:
#   - Local Anvil: http://localhost:8545
#   - Sepolia Testnet: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
#   - Mainnet: https://mainnet.infura.io/v3/YOUR_PROJECT_ID
RPC_URL=https://sei-testnet.g.alchemy.com/v2/<Your_Alchemy_Key>

# ============================================
# Optional: Deployment Verification
# ============================================

# Etherscan API Key (optional, for contract verification)
# Get your API key from: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Network name for verification (optional)
# Examples: sepolia, mainnet, goerli
VERIFY_NETWORK=

RWA_TOKEN=
MINT_TO=